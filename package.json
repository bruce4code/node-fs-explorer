{
  "name": "node-fs-explorer",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @file-manager/server --filter @file-manager/web dev",
    "dev:web": "pnpm --filter @file-manager/web dev",
    "dev:server": "pnpm --filter @file-manager/server dev",
    "cli": "pnpm --filter @file-manager/cli start --",
    "start": "pnpm --filter @file-manager/server start",
    "start:single": "pnpm --filter @file-manager/server start:single",
    "test": "pnpm test:backend && pnpm --filter @file-manager/web test",
    "test:backend": "node --test",
    "test:unit": "node --test test/pathValidator.test.js test/multipartParser.test.js test/router.test.js test/middleware.test.js",
    "test:api": "node --test test/api.test.js",
    "build": "pnpm --filter @file-manager/web build",
    "lint": "pnpm --recursive --if-present lint"
  }
}
